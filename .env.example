# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's already in .gitignore

# ===== SNOWFLAKE CONFIGURATION =====
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=PHARMA_DB
SNOWFLAKE_SCHEMA=BRONZE
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ===== FDA API CONFIGURATION =====
FDA_API_KEY=your_fda_api_key_here
FDA_API_BASE_URL=https://api.fda.gov/drug/event.json

# ===== LOGGING CONFIGURATION =====
LOG_LEVEL=INFO
LOG_FILE=logs/pharmavigilance.log

# ===== ENVIRONMENT =====
ENV=development
# Options: development, staging, production

# ===== DBT CONFIGURATION =====
DBT_PROFILES_DIR=~/.dbt
DBT_TARGET=dev
# Options: dev, prod

# ===== STREAMLIT CONFIGURATION =====
STREAMLIT_CLIENT_TOOLBAR_MODE=minimal
STREAMLIT_CLIENT_LOGGER_LEVEL=warning

# ===== FEATURE FLAGS =====
ENABLE_REAL_TIME_ALERTS=false
ENABLE_ML_ANOMALY_DETECTION=false
ENABLE_POLYPHARMACY_ANALYSIS=true
